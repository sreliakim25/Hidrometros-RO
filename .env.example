# Copie este arquivo para .env.local e preencha as chaves do Supabase
# Painel: https://supabase.com/dashboard/project/<seu-projeto>/settings/api

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Senhas do MODO EDIÇÃO — logins fixos: "nayara" e "erika".
# Se não definir, usa o padrão de desenvolvimento (nayara2026 / erika2026).
# Em produção, defina estes valores nas variáveis de ambiente do Vercel.
VITE_PASS_NAYARA=troque-a-senha-da-nayara
VITE_PASS_ERIKA=troque-a-senha-da-erika
